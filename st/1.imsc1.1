<p xml:id="subtitle458" begin="19247144582t" end="19254235000t" region="region0" style="style2">了解</p>
<p xml:id="subtitle459" begin="19303867916t" end="19315546250t" region="region0" style="style2">〈何事だ？〉</p>
<p xml:id="subtitle460" begin="19323470832t" end="19344742082t" region="region0" style="style2">〈何でもない　寝るわ〉</p>
<p xml:id="subtitle461" begin="19429827082t" end="19440671250t" region="region0" style="style2">署長</p>
<p xml:id="subtitle462" begin="19533680832t" end="19548278750t" region="region0" style="style2">〈一体 何が？〉</p>
<p xml:id="subtitle463" begin="19549530000t" end="19576640416t" region="region0" style="style2">〈ただ嫌な予感が<br/>するだけよ〉</p>
<p xml:id="subtitle464" begin="19585816250t" end="19612092500t" region="region0" style="style2">〈詳細は<br/>分からないけど<span style="style3">⸺</span>〉</p>
<p xml:id="subtitle465" begin="19613760832t" end="19635449166t" region="region0" style="style2">〈夜 起こされたのは<br/>初めて〉</p>
<p xml:id="subtitle466" begin="19636700416t" end="19673403750t" region="region0" style="style2">〈状況を確認しに<br/>行ってくるわ〉</p>
<p xml:id="subtitle467" begin="19682996666t" end="19702182500t" region="region0" style="style2">いつ お戻りに？</p>
<p xml:id="subtitle468" begin="19704685000t" end="19711775416t" region="region0" style="style2">さあ</p>
<p xml:id="subtitle469" begin="19713443750t" end="19733880832t" region="region0" style="style2">玄関の戸締まりは？</p>
<p xml:id="subtitle470" begin="19735132082t" end="19753066666t" region="region0" style="style2">ヴィシャールが</p>
<p xml:id="subtitle471" begin="19764745000t" end="19773920832t" region="region0" style="style2">〈気をつけて〉</p>
<p xml:id="subtitle472" begin="19775172082t" end="19788935832t" region="region0" style="style2">〈ありがとう〉</p>
<p xml:id="subtitle473" begin="20022502500t" end="20034597916t" region="region0" style="style2">詳細は？</p>
<p xml:id="subtitle474" begin="20035849166t" end="20064210832t" region="region0" style="style2">混在した情報しかありません</p>
<p xml:id="subtitle475" begin="20088818750t" end="20097994582t" region="region0" style="style2">急いで</p>
<p xml:id="subtitle476" begin="20331978332t" end="20339902916t" region="region0" style="style2">捜査官？</p>
<p xml:id="subtitle477" begin="20340737082t" end="20347827500t" region="region0" style="style2">はい</p>
<p xml:id="subtitle478" begin="20351998332t" end="20365762082t" region="region0" style="style2">南区のＤＣＰよ</p>
<p xml:id="subtitle479" begin="20368264582t" end="20375355000t" region="region0" style="style2">署長</p>
<p xml:id="subtitle480" begin="20376606250t" end="20392455416t" region="region0" style="style2">被害者はどこ？</p>
<p xml:id="subtitle481" begin="20393289582t" end="20418314582t" region="region0" style="style2">女性は手術を始めます</p>
