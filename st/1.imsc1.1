<p xml:id="subtitle434" begin="18405887500t" end="18430912500t" region="region0" style="style2">こちらイーグル69</p>
<p xml:id="subtitle435" begin="18432997916t" end="18458440000t" region="region0" style="style0">イーグル１　どうぞ</p>
<p xml:id="subtitle436" begin="18459274166t" end="18474289166t" region="region0" style="style2">報告する</p>
