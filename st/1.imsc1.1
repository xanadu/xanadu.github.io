<p xml:id="subtitle483" begin="20499645832t" end="20509655832t" region="region0" style="style2">気をつけて</p>
<p xml:id="subtitle484" begin="20521751250t" end="20536349166t" region="region0" style="style2">〈ＤＣＰです〉</p>
<p xml:id="subtitle485" begin="20537600416t" end="20545942082t" region="region0" style="style2">〈下がって〉</p>
<p xml:id="subtitle486" begin="20547193332t" end="20559288750t" region="region0" style="style2">〈少し話を〉</p>
<p xml:id="subtitle487" begin="20560122916t" end="20570967082t" region="region0" style="style2">〈どうぞ受付に〉</p>
<p xml:id="subtitle488" begin="20571801250t" end="20620600000t" region="region0" style="style2">〈南部地区のＤＣＰです<br/>詳細を聞かせてください〉</p>
<p xml:id="subtitle489" begin="20629358750t" end="20639368750t" region="region0" style="style2">〈それは失礼〉</p>
<p xml:id="subtitle490" begin="20640202916t" end="20655635000t" region="region0" style="style2">〈気になさらず〉</p>
<p xml:id="subtitle491" begin="20657720416t" end="20671901250t" region="region0" style="style2">〈危険な状態です〉</p>
<p xml:id="subtitle492" begin="20673152500t" end="20715695000t" region="region0" style="style2">〈これから損傷部と<br/>腸間膜の緊急手術をします〉</p>
<p xml:id="subtitle493" begin="20718197500t" end="20758654582t" region="region0" style="style2">〈腸が外に出た状態です〉</p>
<p xml:id="subtitle494" begin="20769081666t" end="20779091666t" region="region0" style="style2">〈集団レイプ？〉</p>
<p xml:id="subtitle495" begin="20782428332t" end="20814543750t" region="region0" style="style2">〈ええ<br/>鉄の棒を使ったようです〉</p>
<p xml:id="subtitle496" begin="20826222082t" end="20841237082t" region="region0" style="style2">〈詳細は後で〉</p>
<p xml:id="subtitle497" begin="20842071250t" end="20853749582t" region="region0" style="style2">〈命は？〉</p>
<p xml:id="subtitle498" begin="20861257082t" end="20894623750t" region="region0" style="style2">〈今夜は助かっても<br/>危険な状態です〉</p>
<p xml:id="subtitle499" begin="20899211666t" end="20937583332t" region="region0" style="style2">〈男性に関しては<br/>命に別状はありません〉</p>
<p xml:id="subtitle500" begin="20938417500t" end="20967613332t" region="region0" style="style2">〈Ｘ線とＣＴの結果は<br/>良好です〉</p>
<p xml:id="subtitle501" begin="20969281666t" end="20985965000t" region="region0" style="style2">〈すぐ退院できるはず〉</p>
