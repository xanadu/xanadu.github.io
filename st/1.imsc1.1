<p xml:id="subtitle454" begin="19152883750t" end="19164562082t" region="region0" style="style0">分かりません</p>
<p xml:id="subtitle455" begin="19179994166t" end="19199597082t" region="region0" style="style2">レイプの証拠もなし？</p>
<p xml:id="subtitle456" begin="19200431250t" end="19211275416t" region="region0" style="style2">はい</p>
